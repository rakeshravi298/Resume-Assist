<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Resume – {{name}}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  /* ─── PAGE SETUP ─────────────────────────────── */
  @page { 
    size: A4; 
    margin: 0; 
  }

  *, *::before, *::after { 
    box-sizing: border-box; 
    margin: 0; 
    padding: 0; 
  }

  :root {
    --accent-color: #2563eb;
    --text-main: #1a1a1a;
    --text-muted: #4b5563;
    --text-light: #9ca3af;
    --border-color: #e5e7eb;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    --base-font: 10pt;
    --line-height: 1.45;
    --section-gap: 14px;
    
    font-size: var(--base-font);
    line-height: var(--line-height);
    color: var(--text-main);
    background: white;
    width: 210mm;
    min-height: 297mm;
    padding: 18mm 20mm;
  }

  /* ─── AUTO-SCALING ───────────────────────────── */
  #resume-root {
    width: 170mm; /* 210mm - 40mm total horizontal padding */
  }

  /* ─── TYPOGRAPHY ─────────────────────────────── */
  .name { 
    font-size: 24pt; 
    font-weight: 700; 
    letter-spacing: -0.02em; 
    line-height: 1.1;
    margin-bottom: 4px;
  }
  
  .job-title { 
    font-size: 11pt; 
    font-weight: 500; 
    color: var(--accent-color); 
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .section-heading {
    font-size: 9.5pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-color);
    border-bottom: 1.5px solid var(--accent-color);
    padding-bottom: 4px;
    margin-bottom: 10px;
    margin-top: var(--section-gap);
  }

  .entry + .entry { 
    margin-top: 12px; 
  }

  .entry-title { 
    font-size: 10.5pt; 
    font-weight: 700; 
  }
  
  .entry-sub { 
    font-size: 10pt;  
    font-weight: 600; 
    color: var(--text-muted); 
  }
  
  .entry-date { 
    font-size: 9pt;    
    font-weight: 500; 
    color: var(--text-muted); 
  }
  
  .bullet, .summary-text { 
    font-size: 9.5pt;  
    color: var(--text-main); 
  }

  .contact-item { 
    font-size: 9pt;    
    color: var(--text-muted); 
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* ─── LAYOUT HELPERS ─────────────────────────── */
  .flex-between {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }

  .contact-row {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 20px;
    margin-top: 8px;
  }

  .bullets {
    list-style: none;
    padding-left: 14px;
    margin-top: 5px;
  }

  .bullets li {
    position: relative;
    margin-bottom: 3px;
    line-height: 1.4;
  }

  .bullets li::before {
    content: '•';
    position: absolute;
    left: -14px;
    color: var(--accent-color);
    font-weight: bold;
  }

  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .skill-row {
    display: flex;
    gap: 8px;
    font-size: 9.5pt;
  }

  .skill-label {
    font-weight: 700;
    min-width: 120px;
    color: var(--text-muted);
  }

  .skill-items {
    color: var(--text-main);
  }

</style>
</head>
<body>
<div id="resume-root">

  <!-- ── HEADER ─────────────────────────────── -->
  <header class="header-section">
    <div class="name">{{name}}</div>
    <div class="job-title">{{title}}</div>
    <div class="contact-row">
      {{#if email}}<span class="contact-item">✉ {{email}}</span>{{/if}}
      {{#if phone}}<span class="contact-item">☏ {{phone}}</span>{{/if}}
      {{#if location}}<span class="contact-item">📍 {{location}}</span>{{/if}}
      {{#if linkedin}}<span class="contact-item">in/{{linkedin}}</span>{{/if}}
      {{#if github}}<span class="contact-item">github.com/{{github}}</span>{{/if}}
      {{#if website}}<span class="contact-item">🌐 {{website}}</span>{{/if}}
    </div>
  </header>

  <!-- ── SUMMARY ────────────────────────────── -->
  {{#if summary}}
  <div class="section-heading">Summary</div>
  <p class="summary-text">{{summary}}</p>
  {{/if}}

  <!-- ── EXPERIENCE ─────────────────────────── -->
  {{#if experience.length}}
  <div class="section-heading">Professional Experience</div>
  {{#each experience}}
  <div class="entry">
    <div class="flex-between">
      <span class="entry-title">{{role}}</span>
      <span class="entry-date">{{duration}}</span>
    </div>
    <div class="flex-between">
      <span class="entry-sub">{{company}}</span>
      {{#if location}}<span class="entry-date">{{location}}</span>{{/if}}
    </div>
    {{#if bullets.length}}
    <ul class="bullets">
      {{#each bullets}}<li class="bullet">{{this}}</li>{{/each}}
    </ul>
    {{/if}}
  </div>
  {{/each}}
  {{/if}}

  <!-- ── EDUCATION ──────────────────────────── -->
  {{#if education.length}}
  <div class="section-heading">Education</div>
  {{#each education}}
  <div class="entry">
    <div class="flex-between">
      <span class="entry-title">{{institution}}</span>
      <span class="entry-date">{{year}}</span>
    </div>
    <div class="flex-between">
      <span class="entry-sub">{{degree}}</span>
      {{#if gpa}}<span class="entry-date">GPA: {{gpa}}</span>{{/if}}
    </div>
  </div>
  {{/each}}
  {{/if}}

  <!-- ── PROJECTS ───────────────────────────── -->
  {{#if projects.length}}
  <div class="section-heading">Projects</div>
  {{#each projects}}
  <div class="entry">
    <div class="flex-between">
      <span class="entry-title">{{name}}{{#if link}} | <span style="font-weight:400;font-size:9pt;color:var(--accent-color)">{{link}}</span>{{/if}}</span>
      {{#if tech}}<span class="entry-date">{{tech}}</span>{{/if}}
    </div>
    {{#if description}}<p class="bullet" style="margin-top:2px">{{description}}</p>{{/if}}
  </div>
  {{/each}}
  {{/if}}

  <!-- ── SKILLS ─────────────────────────────── -->
  {{#if skills.categories.length}}
  <div class="section-heading">Skills</div>
  <div class="skills-grid">
    {{#each skills.categories}}
    <div class="skill-row">
      <span class="skill-label">{{label}}:</span>
      <span class="skill-items">{{items}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  <!-- ── CERTIFICATIONS ─────────────────────── -->
  {{#if certifications.length}}
  <div class="section-heading">Certifications</div>
  {{#each certifications}}
  <div class="entry">
    <div class="flex-between">
      <span class="entry-title">{{name}}</span>
      <span class="entry-date">{{year}}</span>
    </div>
    <span class="entry-sub">{{issuer}}</span>
  </div>
  {{/each}}
  {{/if}}

</div><!-- #resume-root -->

<script>
  /**
   * Progressive auto-fit logic:
   * 1. Shrink font-size (floor 8pt)
   * 2. Shrink line-height (floor 1.1)
   * 3. Shrink section margins (floor 4px)
   * 4. Nuclear fallback: scale()
   */
  function autoFit(rootEl, a4HeightPx = 1122) {
    const style = rootEl.style;
    let fontSize   = parseFloat(getComputedStyle(rootEl).fontSize) || 13.33; // 10pt ~ 13.33px
    let lineHeight = parseFloat(getComputedStyle(rootEl).lineHeight) / fontSize || 1.45;
    let sectionGap = 14;

    const fits = () => rootEl.scrollHeight <= a4HeightPx;

    // Pass 1: font size (0.1pt steps)
    while (!fits() && fontSize > 10.66) { // 8pt ~ 10.66px
      fontSize -= 0.133; // ~0.1pt
      rootEl.style.setProperty('--base-font', `${(fontSize * 0.75).toFixed(2)}pt`);
    }

    // Pass 2: line-height
    while (!fits() && lineHeight > 1.1) {
      lineHeight -= 0.05;
      rootEl.style.setProperty('--line-height', `${lineHeight.toFixed(2)}`);
    }

    // Pass 3: section gap
    while (!fits() && sectionGap > 4) {
      sectionGap -= 1;
      rootEl.style.setProperty('--section-gap', `${sectionGap}px`);
    }

    // Nuclear fallback: content is just way too long
    if (!fits()) {
      const scale = a4HeightPx / rootEl.scrollHeight;
      style.transform = `scale(${scale})`;
      style.transformOrigin = 'top left';
      document.body.style.height = a4HeightPx + 'px';
      document.body.style.overflow = 'hidden';
    }
  }

  // Run immediately
  (function() {
    autoFit(document.getElementById('resume-root'));
  })();
</script>
</body>
</html>
